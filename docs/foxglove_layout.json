{
  "configById": {
    "3D!main": {
      "cameraState": {
        "perspective": true,
        "distance": 18,
        "phi": 55,
        "thetaOffset": 45,
        "targetOffset": [0, 0, 0],
        "target": [0, 0, 0],
        "targetOrientation": [0, 0, 0, 1],
        "fovy": 45,
        "near": 0.5,
        "far": 5000
      },
      "followMode": "follow-pose",
      "followTf": "base_link",
      "scene": {
        "enableStats": false,
        "backgroundColor": "#101418",
        "transforms": {
          "showLabel": false,
          "axisScale": 0.5,
          "lineWidth": 1.5
        }
      },
      "transforms": {
        "frame:map":              { "visible": false },
        "frame:odom":             { "visible": false },
        "frame:base_footprint":   { "visible": false },
        "frame:base_link":        { "visible": true },
        "frame:imu_link":         { "visible": false },
        "frame:velodyne":         { "visible": true },
        "frame:zed_front_camera_link":          { "visible": true },
        "frame:zed_front_camera_center":        { "visible": false },
        "frame:zed_front_left_camera_frame":    { "visible": false },
        "frame:zed_front_left_camera_frame_optical":  { "visible": false },
        "frame:zed_front_right_camera_frame":   { "visible": false },
        "frame:zed_front_right_camera_frame_optical": { "visible": false },
        "frame:zed_left_camera_link":           { "visible": false },
        "frame:zed_left_camera_center":         { "visible": false },
        "frame:zed_left_left_camera_frame":     { "visible": false },
        "frame:zed_left_left_camera_frame_optical":   { "visible": false },
        "frame:zed_left_right_camera_frame":    { "visible": false },
        "frame:zed_left_right_camera_frame_optical":  { "visible": false },
        "frame:zed_right_camera_link":          { "visible": false },
        "frame:zed_right_camera_center":        { "visible": false },
        "frame:zed_right_left_camera_frame":    { "visible": false },
        "frame:zed_right_left_camera_frame_optical":  { "visible": false },
        "frame:zed_right_right_camera_frame":   { "visible": false },
        "frame:zed_right_right_camera_frame_optical": { "visible": false }
      },
      "topics": {
        "/robot_description": {
          "visible": true,
          "color": "#888888aa"
        },
        "/local_costmap/costmap": {
          "visible": true,
          "colorMode": "costmap",
          "alpha": 0.85,
          "frameLocked": false,
          "minColor": "#00000000",
          "maxColor": "#ff0000ff"
        },
        "/perception/front/semantic_points": {
          "visible": true,
          "pointSize": 4,
          "colorField": "rgb",
          "colorMode": "rgb"
        },
        "/local_costmap/front/tile_map": {
          "visible": false,
          "pointSize": 6,
          "colorField": "class",
          "colorMode": "colormap",
          "colorMap": "turbo"
        },
        "/velodyne_points": {
          "visible": false,
          "pointSize": 1,
          "colorField": "intensity",
          "colorMode": "colormap",
          "colorMap": "turbo"
        }
      },
      "imageMode": {},
      "publish": {
        "type": "pose_estimate",
        "poseTopic": "/initialpose",
        "pointTopic": "/clicked_point",
        "poseEstimateTopic": "/initialpose",
        "poseEstimateXDeviation": 0.5,
        "poseEstimateYDeviation": 0.5,
        "poseEstimateThetaDeviation": 0.26
      }
    },
    "Image!overlay": {
      "cameraState": {
        "distance": 1.5
      },
      "followTf": "zed_front_left_camera_frame_optical",
      "imageMode": {
        "imageTopic": "/perception/front/overlay",
        "calibrationTopic": "/zed_front/zed_node/rgb/color/rect/camera_info",
        "synchronize": true,
        "rotation": 0,
        "minValue": 0,
        "maxValue": 255
      },
      "topics": {}
    },
    "Image!raw": {
      "cameraState": {
        "distance": 1.5
      },
      "followTf": "zed_front_left_camera_frame_optical",
      "imageMode": {
        "imageTopic": "/zed_front/zed_node/rgb/color/rect/image",
        "calibrationTopic": "/zed_front/zed_node/rgb/color/rect/camera_info",
        "synchronize": true,
        "rotation": 0
      },
      "topics": {}
    },
    "Indicator!actuator": {
      "path": "/avros/actuator_state.estop",
      "style": "background",
      "fallbackColor": "#666666",
      "fallbackLabel": "no data",
      "rules": [
        { "operator": "=", "rawValue": "true",  "color": "#ff3333", "label": "ESTOP" },
        { "operator": "=", "rawValue": "false", "color": "#33aa33", "label": "READY" }
      ]
    },
    "RawMessages!params": {
      "topicPath": "/perception/front/label_info"
    }
  },
  "globalVariables": {},
  "userNodes": {},
  "playbackConfig": { "speed": 1 },
  "layout": {
    "direction": "row",
    "first": "3D!main",
    "second": {
      "direction": "column",
      "first": "Image!overlay",
      "second": {
        "direction": "column",
        "first": "Image!raw",
        "second": "Indicator!actuator",
        "splitPercentage": 80

      },
      "splitPercentage": 50
    },
    "splitPercentage": 60
  }
}
