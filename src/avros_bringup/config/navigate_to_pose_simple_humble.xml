<!--
  Minimal navigate_to_pose BT — ComputePathToPose -> FollowPath, no recoveries.

  Purpose: test whether the planner (SmacPlannerHybrid / GridBased) routes around
  costmap LETHAL cells (e.g. painted lane lines from the kiwicampus semantic_layer)
  when sent an arbitrary forward goal. No recoveries means a failed plan or stuck
  controller surfaces immediately rather than being silently retried.

  Compared to the route-graph BT:
    - No ComputeRoute / route_server dependency — works for any goal pose, not
      just locations near pre-defined graph nodes.
    - No ClearLocalCostmap on failure (would defeat the whole point of seeing
      whether the planner avoids the LETHAL cells).
    - No spin / backup / wait recoveries — clean signal: it either plans + drives,
      or it doesn't.

  Use via: ros2 launch avros_bringup navigation.launch.py bt_xml:=navigate_to_pose_simple_humble.xml
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="NavigateWithReplanning">
      <RateController hz="1.0">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPath" goal_checker_id="general_goal_checker"/>
    </PipelineSequence>
  </BehaviorTree>
</root>
