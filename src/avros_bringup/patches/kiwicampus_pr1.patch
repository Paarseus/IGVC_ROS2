From 8451e3de8161a7c980667ce9de075cf7a5ed9523 Mon Sep 17 00:00:00 2001
From: Pantelis Manouselis <p.manouselis@saxion.nl>
Date: Mon, 9 Feb 2026 10:48:49 +0100
Subject: [PATCH] Backport to Humble (Colcon builds successfully)

---
 CMakeLists.txt                                | 52 +++++++------------
 .../segmentation_buffer.hpp                   |  2 +
 2 files changed, 22 insertions(+), 32 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d003509..0cce131 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,18 +1,15 @@
 cmake_minimum_required(VERSION 3.8)
 project(semantic_segmentation_layer)
 
-# Default to C++17
 if(CMAKE_COMPILER_IS_GNUCXX OR CMAKE_CXX_COMPILER_ID MATCHES "Clang")
   add_compile_options(-Wall -Wextra -Wpedantic)
 endif()
 
-# Find dependencies
 find_package(ament_cmake REQUIRED)
 find_package(geometry_msgs REQUIRED)
 find_package(message_filters REQUIRED)
 find_package(nav2_costmap_2d REQUIRED)
 find_package(nav2_util REQUIRED)
-find_package(nav2_util REQUIRED)
 find_package(nav_msgs REQUIRED)
 find_package(pluginlib REQUIRED)
 find_package(rclcpp REQUIRED)
@@ -25,60 +22,51 @@ find_package(tf2_geometry_msgs REQUIRED)
 find_package(tf2_sensor_msgs REQUIRED)
 find_package(vision_msgs REQUIRED)
 
-# Include directories
-include_directories(include)
-
-# Create the semantic segmentation layer library
-add_library(semantic_segmentation_layer SHARED
+add_library(${PROJECT_NAME} SHARED
   src/semantic_segmentation_layer.cpp
   src/segmentation_buffer.cpp
 )
 
-target_include_directories(semantic_segmentation_layer
+target_include_directories(${PROJECT_NAME}
   PUBLIC
     $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
     $<INSTALL_INTERFACE:include>
 )
 
-target_link_libraries(semantic_segmentation_layer
-  PUBLIC
-    message_filters::message_filters
-    nav2_costmap_2d::nav2_costmap_2d_core
-    nav2_util::nav2_util_core
-    nav2_util::nav2_util_core
-    pluginlib::pluginlib
-    rclcpp::rclcpp
-    rclcpp_lifecycle::rclcpp_lifecycle
-    tf2::tf2
-    tf2_ros::tf2_ros
-    tf2_sensor_msgs::tf2_sensor_msgs
-    ${vision_msgs_TARGETS}
+# Humble-compatible: let ament handle include dirs + libs
+ament_target_dependencies(${PROJECT_NAME}
+  geometry_msgs
+  message_filters
+  nav2_costmap_2d
+  nav2_util
+  nav_msgs
+  pluginlib
+  rclcpp
+  rclcpp_lifecycle
+  sensor_msgs
+  std_msgs
+  tf2
+  tf2_ros
+  tf2_geometry_msgs
+  tf2_sensor_msgs
+  vision_msgs
 )
 
-# Install library
-install(TARGETS semantic_segmentation_layer
+install(TARGETS ${PROJECT_NAME}
   ARCHIVE DESTINATION lib
   LIBRARY DESTINATION lib
   RUNTIME DESTINATION bin
 )
 
-# Install header files
 install(DIRECTORY include/
   DESTINATION include
 )
 
-# Install plugin description file
 install(FILES costmap_plugins.xml
   DESTINATION share/${PROJECT_NAME}
 )
 
-# Export plugin description file for pluginlib
 pluginlib_export_plugin_description_file(nav2_costmap_2d costmap_plugins.xml)
 
-if(BUILD_TESTING)
-  find_package(ament_lint_auto REQUIRED)
-  ament_lint_auto_find_test_dependencies()
-endif()
-
 ament_package()
 
diff --git a/include/semantic_segmentation_layer/segmentation_buffer.hpp b/include/semantic_segmentation_layer/segmentation_buffer.hpp
index 78e5160..8316e88 100644
--- a/include/semantic_segmentation_layer/segmentation_buffer.hpp
+++ b/include/semantic_segmentation_layer/segmentation_buffer.hpp
@@ -42,6 +42,8 @@
 #include <list>
 #include <string>
 #include <vector>
+#include <deque>
+
 
 #include "nav2_util/lifecycle_node.hpp"
 #include "rclcpp/time.hpp"
